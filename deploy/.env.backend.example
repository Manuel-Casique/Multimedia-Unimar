FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=

SANCTUM_STATEFUL_DOMAINS=unimar.localhost

GEMINI_API_KEY=

GOOGLE_CLIENT_ID=
