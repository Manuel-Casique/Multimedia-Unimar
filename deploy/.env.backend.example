APP_NAME=Unimar
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://unimar.localhost
APP_TIMEZONE=America/Caracas

LOG_CHANNEL=stderr
