{
    auto_https off
    admin off
}

:80 {
    # Allow large file uploads (videos up to 1 GB)
    request_body {
        max_size 1536MB
    }

    # Route API and Laravel internals to the backend
    @backend {
        path /api/*
        path /sanctum/*
        path /storage/*
    }

    reverse_proxy @backend backend:8000

    # Everything else goes to Next.js
    reverse_proxy frontend:3000
}
